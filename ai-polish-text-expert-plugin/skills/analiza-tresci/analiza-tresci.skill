              new TextRun({ children: [new PageNumber(PageNumberFormat.DECIMAL)], font: "Aptos", size: 16, color: "888888" })
            ],
            border: { top: { style: BorderStyle.SINGLE, size: 4, color: "CCCCCC", space: 1 } }
          })
        ]
      })
    },
